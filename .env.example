# ── rag-thesis: Beispiel-Konfiguration ───────────────────────────────────────
# Kopieren nach `.env` und Werte anpassen:  cp .env.example .env
# Alle Werte außer OPENAI_API_KEY sind optional und haben Defaults in config.py.

# ── Pflicht ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Eingabe-PDF (liegt unter data/) ───────────────────────────────────────────
PDF_FILENAME=vorlesung.pdf

# ── Modelle ───────────────────────────────────────────────────────────────────
# Routing: günstig fürs Schreiben (mini), stark fürs Bewerten (gpt-4o).
MODEL_TEXT=gpt-4o-mini
MODEL_TEXT_ADVANCED=gpt-4o
MODEL_VISION=gpt-4o-mini
MODEL_JUDGE=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ── LLM-Hyperparameter ────────────────────────────────────────────────────────
TEMPERATURE=0.0
TEMPERATURE_GENERATION=0.3
RANDOM_SEED=42

# ── Retrieval / Chunking ──────────────────────────────────────────────────────
TOP_K=8
CHUNK_TARGET_SIZE=1200
CHUNK_OVERLAP=150

# ── Ground-Truth-Generierung ──────────────────────────────────────────────────
WINDOW_SIZE=7
WINDOW_STRIDE=3

# ── PDF-Ingestion ─────────────────────────────────────────────────────────────
# START_PAGE=1
# END_PAGE=
FOOTER_CUTOFF_RATIO=0.1
HEADER_CUTOFF_RATIO=0.0
MAX_IMAGE_DIM=1024
# Mindest-Kantenlänge (px), ab der ein eingebettetes Bild analysiert wird.
MIN_IMAGE_SIZE=100
# Detailgrad der Vision-Analyse: low | high (high = genauer, aber teurer).
IMAGE_DETAIL=high

# ── Parallelisierung & Rate-Limiting ──────────────────────────────────────────
MAX_WORKERS=12
MAX_WORKERS_JUDGE=5
JUDGE_TPM_LIMIT=25000
OPENAI_REQUEST_TIMEOUT=60.0

# ── Persistenz / Debugging ────────────────────────────────────────────────────
# Rohe LLM-Antworten zusätzlich speichern (1/true/yes). Default aus.
SAVE_RAW_RESPONSES=0
