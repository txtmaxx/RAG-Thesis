__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Betriebssystem / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
